# =============================================================================
# COMMAND: check
# =============================================================================

cmd_check() {
  echo ""
  echo -e "${BOLD}=== Health Check: ${APP_NAME} (${ENV_NAME}) ===${NC}"
  echo ""

  local pass=0
  local fail=0
  local warn_count=0

  check_pass() { echo -e "  ${GREEN}✓${NC} $1"; pass=$((pass + 1)); }
  check_fail() { echo -e "  ${RED}✗${NC} $1"; fail=$((fail + 1)); }
  check_warn() { echo -e "  ${YELLOW}!${NC} $1"; warn_count=$((warn_count + 1)); }

  # -------------------------------------------------------------------------
  # 1. SSH connectivity
  # -------------------------------------------------------------------------
  echo -e "${BOLD}Server${NC}"
  if ssh -q -o ConnectTimeout=5 "${SSH_USER}@${SSH_HOST}" "echo ok" > /dev/null 2>&1; then
    check_pass "SSH connection to ${SSH_USER}@${SSH_HOST}"
  else
    check_fail "SSH connection to ${SSH_USER}@${SSH_HOST}"
    error "Cannot reach server — remaining checks require SSH"
  fi

  # -------------------------------------------------------------------------
  # 2. Shared infrastructure
  # -------------------------------------------------------------------------
  echo ""
  echo -e "${BOLD}Shared Infrastructure${NC}"

  # Traefik
  local traefik_status
  traefik_status=$(remote "docker inspect -f '{{.State.Status}}' traefik 2>/dev/null" || echo "missing")
  if [ "$traefik_status" = "running" ]; then
    check_pass "Traefik is running"
  else
    check_fail "Traefik is ${traefik_status}"
  fi

  # Postgres
  local pg_status
  pg_status=$(remote "docker inspect -f '{{.State.Status}}' shared-postgres 2>/dev/null" || echo "missing")
  if [ "$pg_status" = "running" ]; then
    local pg_ready
    pg_ready=$(remote "docker exec shared-postgres pg_isready 2>/dev/null" || echo "not ready")
    if echo "$pg_ready" | grep -q "accepting connections"; then
      check_pass "Postgres is running and accepting connections"
    else
      check_warn "Postgres container running but not accepting connections"
    fi
  else
    check_fail "Postgres is ${pg_status}"
  fi

  # Redis
  local redis_status
  redis_status=$(remote "docker inspect -f '{{.State.Status}}' shared-redis 2>/dev/null" || echo "missing")
  if [ "$redis_status" = "running" ]; then
    local redis_ping
    redis_ping=$(remote "set -a && source /opt/shared/.env && set +a && docker exec shared-redis redis-cli -a \"\$REDIS_PASSWORD\" ping 2>/dev/null" || echo "fail")
    if echo "$redis_ping" | grep -q "PONG"; then
      check_pass "Redis is running and responding"
    else
      check_warn "Redis container running but not responding to PING"
    fi
  else
    check_fail "Redis is ${redis_status}"
  fi

  # -------------------------------------------------------------------------
  # 3. App containers
  # -------------------------------------------------------------------------
  echo ""
  echo -e "${BOLD}App Containers${NC}"

  local app_status
  app_status=$(remote "docker inspect -f '{{.State.Status}}' ${APP_NAME}-app 2>/dev/null" || echo "missing")
  if [ "$app_status" = "running" ]; then
    check_pass "App container (${APP_NAME}-app) is running"

    # Check for restart loops
    local restart_count
    restart_count=$(remote "docker inspect -f '{{.RestartCount}}' ${APP_NAME}-app 2>/dev/null" || echo "0")
    if [ "$restart_count" -gt 5 ] 2>/dev/null; then
      check_warn "App has restarted ${restart_count} times (possible crash loop)"
    fi

    # Recent logs check for errors
    local error_lines
    error_lines=$(remote "docker logs ${APP_NAME}-app --tail 50 2>&1 | grep -ciE 'error|exception|fatal|crash'" || echo "0")
    if [ "$error_lines" -gt 3 ] 2>/dev/null; then
      check_warn "Found ${error_lines} error lines in recent logs"
    fi
  else
    check_fail "App container (${APP_NAME}-app) is ${app_status}"
    if [ "$app_status" != "missing" ]; then
      echo ""
      echo -e "  ${YELLOW}Last 10 log lines:${NC}"
      remote "docker logs ${APP_NAME}-app --tail 10 2>&1" | while IFS= read -r line; do
        echo "    $line"
      done
    fi
  fi

  # Extra containers from config
  for container in $EXTRA_CONTAINERS; do
    local c_status
    c_status=$(remote "docker inspect -f '{{.State.Status}}' ${APP_NAME}-${container} 2>/dev/null" || echo "missing")
    if [ "$c_status" = "running" ]; then
      check_pass "${container} (${APP_NAME}-${container}) is running"
    elif [ "$c_status" = "missing" ]; then
      check_warn "${container} (${APP_NAME}-${container}) not found"
    else
      check_warn "${container} (${APP_NAME}-${container}) is ${c_status}"
    fi
  done

  # -------------------------------------------------------------------------
  # 4. HTTP health checks
  # -------------------------------------------------------------------------
  echo ""
  echo -e "${BOLD}HTTP Health${NC}"

  # Internal health check (via docker exec)
  local internal_health
  internal_health=$(remote "docker exec ${APP_NAME}-app wget -q -O- http://localhost:${APP_PORT}${HEALTH_PATH} 2>/dev/null" || echo "")
  if echo "$internal_health" | grep -qE "${HEALTH_MATCH}"; then
    check_pass "Internal health check (app:${APP_PORT}${HEALTH_PATH}) — OK"
  elif [ -n "$internal_health" ]; then
    check_warn "Internal health check responded but didn't match expected pattern"
  else
    check_fail "Internal health check — no response"
  fi

  # Traefik routing check (from server via curl to localhost)
  local traefik_health
  traefik_health=$(remote "curl -sf http://localhost/${APP_NAME}${HEALTH_PATH} 2>/dev/null" || echo "")
  if echo "$traefik_health" | grep -qE "${HEALTH_MATCH}"; then
    check_pass "Traefik path routing (/${APP_NAME}${HEALTH_PATH}) — OK"
  elif [ -n "$traefik_health" ]; then
    check_warn "Traefik responded but didn't match expected pattern"
  else
    check_warn "Traefik path routing — no response (domain routing may still work)"
  fi

  # -------------------------------------------------------------------------
  # 5. Domain & SSL (if configured)
  # -------------------------------------------------------------------------
  if [ -n "$APP_DOMAIN" ]; then
    echo ""
    echo -e "${BOLD}Domain & SSL${NC}"

    # DNS resolution
    local resolved_ip
    resolved_ip=$(dig +short "$APP_DOMAIN" 2>/dev/null | head -1)
    if [ "$resolved_ip" = "$SSH_HOST" ]; then
      check_pass "DNS: ${APP_DOMAIN} → ${SSH_HOST}"
    elif [ -n "$resolved_ip" ]; then
      check_fail "DNS: ${APP_DOMAIN} → ${resolved_ip} (expected ${SSH_HOST})"
    else
      check_fail "DNS: ${APP_DOMAIN} does not resolve"
    fi

    # HTTPS check (from local machine)
    local https_response
    https_response=$(curl -sf --max-time 10 "https://${APP_DOMAIN}${HEALTH_PATH}" 2>/dev/null || echo "")
    if echo "$https_response" | grep -qE "${HEALTH_MATCH}"; then
      check_pass "HTTPS: https://${APP_DOMAIN}${HEALTH_PATH} — OK"
    elif [ -n "$https_response" ]; then
      check_warn "HTTPS: responded but didn't match expected pattern"
    else
      check_fail "HTTPS: https://${APP_DOMAIN} — no response (SSL cert or routing issue)"
    fi

    # SSL certificate check
    local ssl_expiry
    ssl_expiry=$(echo | openssl s_client -servername "$APP_DOMAIN" -connect "${APP_DOMAIN}:443" 2>/dev/null | openssl x509 -noout -enddate 2>/dev/null | cut -d= -f2)
    if [ -n "$ssl_expiry" ]; then
      check_pass "SSL certificate valid until: ${ssl_expiry}"
    else
      check_warn "SSL certificate not available yet"
    fi
  fi

  # -------------------------------------------------------------------------
  # 6. Disk & memory
  # -------------------------------------------------------------------------
  echo ""
  echo -e "${BOLD}Server Resources${NC}"

  local disk_usage
  disk_usage=$(remote "df -h / | tail -1 | awk '{print \$5}'" || echo "unknown")
  local disk_pct=${disk_usage%\%}
  if [ "$disk_pct" -lt 80 ] 2>/dev/null; then
    check_pass "Disk usage: ${disk_usage}"
  elif [ "$disk_pct" -lt 90 ] 2>/dev/null; then
    check_warn "Disk usage: ${disk_usage} (getting full)"
  else
    check_fail "Disk usage: ${disk_usage} (critical)"
  fi

  local mem_info
  mem_info=$(remote "free -m | awk '/^Mem:/ {printf \"%dMB / %dMB (%d%%)\", \$3, \$2, \$3*100/\$2}'" || echo "unknown")
  local mem_pct
  mem_pct=$(echo "$mem_info" | grep -oE '[0-9]+%' | tr -d '%')
  if [ "$mem_pct" -lt 80 ] 2>/dev/null; then
    check_pass "Memory: ${mem_info}"
  elif [ "$mem_pct" -lt 90 ] 2>/dev/null; then
    check_warn "Memory: ${mem_info} (high)"
  else
    check_fail "Memory: ${mem_info} (critical)"
  fi

  # -------------------------------------------------------------------------
  # Summary
  # -------------------------------------------------------------------------
  echo ""
  echo -e "${BOLD}─────────────────────────────────${NC}"
  echo -e "  ${GREEN}✓ ${pass} passed${NC}   ${RED}✗ ${fail} failed${NC}   ${YELLOW}! ${warn_count} warnings${NC}"
  echo -e "${BOLD}─────────────────────────────────${NC}"

  if [ "$fail" -gt 0 ]; then
    echo ""
    echo "  Troubleshoot with:"
    echo "    ./deploy logs ${ENV_NAME}      View app logs"
    echo "    ./deploy status ${ENV_NAME}    Container status"
    echo "    ./deploy ssh ${ENV_NAME}       SSH to server"
  elif [ "$warn_count" -gt 0 ]; then
    echo ""
    echo "  Some warnings — app may still be starting up."
    echo "  Re-run in a minute: ./deploy check ${ENV_NAME}"
  else
    echo ""
    if [ -n "$APP_DOMAIN" ]; then
      echo -e "  ${GREEN}All good!${NC} App is live at: https://${APP_DOMAIN}"
    else
      echo -e "  ${GREEN}All good!${NC} App is live at: http://${SSH_HOST}/${APP_NAME}/api/v1"
    fi
  fi
  echo ""
}

# =============================================================================
# COMMAND: ssh
# =============================================================================

cmd_ssh() {
  exec ssh -t "${SSH_USER}@${SSH_HOST}" "cd ${APP_DIR} && exec \$SHELL -l"
}

# =============================================================================
# COMMAND: env
# =============================================================================

cmd_env() {
  remote_check

  local subcmd="${ENV_SUBCMD:-}"

  if [ -z "$subcmd" ]; then
    pick_option "Environment variables (${APP_NAME})" \
      "List          Show all env vars" \
      "Get           Get a specific var" \
      "Set           Set or update a var" \
      "Edit          Open .env in editor" \
      "Restart       Restart app to apply changes"

    case $MENU_RESULT in
      1) subcmd="list" ;;
      2) subcmd="get" ;;
      3) subcmd="set" ;;
      4) subcmd="edit" ;;
      5) subcmd="restart" ;;
    esac
  fi

  case "$subcmd" in
    list)
      echo ""
      echo -e "${BOLD}${APP_NAME} — .env${NC}"
      echo ""
      remote "cat ${APP_DIR}/.env" | while IFS= read -r line; do
        if [[ "$line" =~ ^#.* ]]; then
          echo -e "  ${YELLOW}${line}${NC}"
        elif [[ "$line" =~ ^[A-Z_]+=.+ ]]; then
          local key="${line%%=*}"
          local val="${line#*=}"
          # Mask secrets
          if echo "$key" | grep -qiE 'SECRET|PASSWORD|KEY|TOKEN'; then
            val="${val:0:4}••••"
          fi
          echo -e "  ${CYAN}${key}${NC}=${val}"
        elif [ -n "$line" ]; then
          echo "  $line"
        else
          echo ""
        fi
      done
      echo ""
      ;;

    get)
      local key
      key=$(prompt_required "Variable name")
      key=$(echo "$key" | tr '[:lower:]' '[:upper:]')
      local val
      val=$(remote "grep '^${key}=' ${APP_DIR}/.env | cut -d'=' -f2-")
      if [ -n "$val" ]; then
        echo -e "\n  ${CYAN}${key}${NC}=${val}\n"
      else
        warn "${key} not found in .env"
      fi
      ;;

    set)
      local key
      key=$(prompt_required "Variable name")
      key=$(echo "$key" | tr '[:lower:]' '[:upper:]')

      # Show current value if exists
      local current
      current=$(remote "grep '^${key}=' ${APP_DIR}/.env | cut -d'=' -f2-" 2>/dev/null || echo "")
      if [ -n "$current" ]; then
        info "Current value: ${current}"
      fi

      local val
      val=$(prompt_required "Value for ${key}")

      # Quote if special characters
      if echo "$val" | grep -qE '[<>|&;()$ ]'; then
        val="\"${val}\""
      fi

      # Check if key exists — update or append
      local exists
      exists=$(remote "grep -c '^${key}=' ${APP_DIR}/.env" 2>/dev/null || echo "0")
      if [ "$exists" -gt 0 ]; then
        remote "sed -i 's|^${key}=.*|${key}=${val}|' ${APP_DIR}/.env"
        info "Updated ${key}"
      else
        remote "echo '${key}=${val}' >> ${APP_DIR}/.env"
        info "Added ${key}"
      fi

      echo ""
      if confirm "Restart app to apply?"; then
        remote "cd ${APP_DIR} && set -a && source .env && set +a && docker compose -f docker-compose.prod.yml restart app" 2>&1
        info "App restarted"
      else
        warn "Remember to restart: ./deploy restart ${ENV_NAME}"
      fi
      ;;

    edit)
      ssh -t "${SSH_USER}@${SSH_HOST}" "nano ${APP_DIR}/.env || vi ${APP_DIR}/.env"
      echo ""
      if confirm "Restart app to apply changes?"; then
        remote "cd ${APP_DIR} && set -a && source .env && set +a && docker compose -f docker-compose.prod.yml restart app" 2>&1
        info "App restarted"
      fi
      ;;

    restart)
      info "Restarting ${APP_NAME}..."
      remote "cd ${APP_DIR} && set -a && source .env && set +a && docker compose -f docker-compose.prod.yml restart app" 2>&1
      info "Done"
      ;;
  esac
}

# =============================================================================
# COMMAND: restart
# =============================================================================

cmd_restart() {
  remote_check
  info "Restarting ${APP_NAME}..."
  remote "cd ${APP_DIR} && set -a && source .env && set +a && docker compose -f docker-compose.prod.yml restart app" 2>&1
  info "Done"
}

