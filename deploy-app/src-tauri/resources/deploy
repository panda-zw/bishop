case "$COMMAND" in
  init)
    cmd_init
    ;;
  setup-github)
    cmd_setup_github
    ;;
  setup-project)
    cmd_setup_project
    ;;
  setup-server)
    parse_remote
    echo ""
    info "Environment: ${ENV_NAME}"
    info "Server:      ${SSH_USER}@${SSH_HOST}"
    echo ""
    cmd_setup_server
    ;;
  setup-app)
    parse_remote
    echo ""
    info "Environment: ${ENV_NAME}"
    info "Server:      ${SSH_USER}@${SSH_HOST}"
    info "App name:    ${APP_NAME}"
    [ -n "$APP_DOMAIN" ] && info "Domain:      ${APP_DOMAIN}"
    echo ""
    cmd_setup_app
    ;;
  deploy)
    parse_remote
    echo ""
    info "Environment: ${ENV_NAME}"
    info "Server:      ${SSH_USER}@${SSH_HOST}"
    info "App name:    ${APP_NAME}"
    [ -n "$APP_DOMAIN" ] && info "Domain:      ${APP_DOMAIN}"
    echo ""
    cmd_deploy
    ;;
  check)
    parse_remote
    cmd_check
    ;;
  logs)
    parse_remote
    cmd_logs
    ;;
  status)
    parse_remote
    cmd_status
    ;;
  ssh)
    parse_remote
    cmd_ssh
    ;;
  env)
    parse_remote
    # Support ./deploy env set staging KEY=VALUE shorthand
    ENV_SUBCMD="${3:-}"
    cmd_env
    ;;
  restart)
    parse_remote
    cmd_restart
    ;;
  *)
    error "Unknown command: ${COMMAND}"
    ;;
esac
