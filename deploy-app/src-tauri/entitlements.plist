<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Network client — Bishop opens SSH + HTTPS connections. -->
  <key>com.apple.security.network.client</key>
  <true/>

  <!-- Lets the app exec /usr/bin/ssh, /usr/local/bin/docker, tmux, etc. -->
  <key>com.apple.security.cs.allow-jit</key>
  <false/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <false/>

  <!-- Read-only access outside the sandbox so the app can parse ~/.ssh/config,
       read project compose files from anywhere the user picks, etc. -->
  <key>com.apple.security.files.user-selected.read-write</key>
  <true/>
</dict>
</plist>
