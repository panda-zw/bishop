{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bishop",
  "version": "0.1.1",
  "identifier": "dev.bishop.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Bishop",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources/deploy"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "entitlements.plist",
      "minimumSystemVersion": "11.0"
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDUyRTA5MDA0NTlGMDgxRUYKUldUdmdmQlpCSkRnVXNtNjFWNDRraE5OL1FibXJlWnRiQ3dwUU5UM0x1Q2VlSktKdkk1MjZKWXUK",
      "endpoints": [
        "https://github.com/panda-zw/bishop/releases/latest/download/latest.json"
      ]
    }
  }
}
